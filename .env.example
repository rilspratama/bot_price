TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_BOT_TOKEN=your_bot_token

# Optional: limit EVM wallet-balance fallback chains, for example: Ethereum,Base,BNB
# Leave empty to use all default chains.
RPC_BALANCE_CHAINS=

# Optional: Pyrogram session directory. Docker Compose sets this automatically.
PYROGRAM_WORKDIR=.
